{
    "expo": {
        "name": "rider_app",
        "slug": "rider_app",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./src/assets/images/icon.png",
        "scheme": "myapp",
        "newArchEnabled": true,
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./src/assets/images/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.sanjay.riderapp"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/images/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "com.sanjay.riderapp"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./src/assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-location",
                {
                    "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
                }
            ],
            [
                "react-native-maps",
                {
                    "googleMaps": {
                        "ios": {
                            "apiKey": "AIzaSyAPgIx_sdOWXxskpDi-kK2dGYf1yo7cTj8"
                        },
                        "android": {
                            "apiKey": "AIzaSyAPgIx_sdOWXxskpDi-kK2dGYf1yo7cTj8"
                        }
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}